# Django Settings
# برای استفاده، این فایل را به .env کپی کنید و مقادیر را تنظیم کنید

# SECRET_KEY: کلید امنیتی Django (اجباری)
# برای تولید کلید جدید:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here

# DEBUG: حالت دیباگ (True/False)
DEBUG=True

# ALLOWED_HOSTS: لیست هاست‌های مجاز (با کاما جدا کنید)
ALLOWED_HOSTS=localhost,127.0.0.1

# محدودیت‌های برنامه
MAX_TEXT_LENGTH=10000
MAX_WORDS=2000

# مسیر Graphviz (اختیاری - فقط برای Windows)
# برای Linux/Mac معمولاً نیازی به تنظیم نیست
GRAPHVIZ_PATH=C:\Program Files\Graphviz\bin

